{
  "productName": "QEntry",
  "appId": "com.improjects.qentry",
  "directories": {
    "output": "dist_electron"
  },
  "extraMetadata": {
    "main": "electron.js"
  },
  "files": [
    "electron.js",
    "preload.js",
    "frontend/dist",
    "backend",
    "package.json",
    "package-lock.json"
  ],
  "extraResources": [
    {
      "from": "backend/node_modules",
      "to": "node_modules"
    }
  ],
  "asar": false,
  "mac": {
    "target": "dmg",
    "icon": "frontend/src/assets/QEntry-logo.png"
  },
  "win": {
    "target": "nsis",
    "icon": "frontend/src/assets/QEntry-logo.png"
  }
}