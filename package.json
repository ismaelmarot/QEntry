{
  "name": "qentry",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de gestión de entradas y salidas con QR",
  "author": "Ismael Marot <ismael.marot@improjects.com>",
  "main": "electron.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run electron\"",
    "package": "electron-builder",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && node index.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
